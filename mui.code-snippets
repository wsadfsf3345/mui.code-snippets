{
	"MUI template": {
		"prefix": "miui",
		"body": [
			"<!doctype html>",
			"<html>",
			"",
			"\t<head>",
			"\t\t<meta charset=\"utf-8\">",
			"\t\t<title></title>",
			"\t\t<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no\" />",
			"\t\t<link href=\"css/mui.css\" rel=\"stylesheet\" />",
			"\t</head>",
			"",
			"\t<body>",
			"\t\t<script src=\"js/mui.js\"></script>",
			"\t\t<script type=\"text/javascript\">",
			"\t\t\tmui.init()",
			"\t\t</script>",
			"\t</body>",
			"",
			"</html>"
		],
		"description": "MUI通用HTML模板"
	},
	"MUI Heder": {
		"prefix": "mheader",
		"body": [
			"<header class=\"mui-bar mui-bar-nav\">",
			"\t<h1 class=\"mui-title\">标题</h1>",
			"</header>",
		],
		"description": "MUI标题栏"
	},
	"MUI Heder1": {
		"prefix": "mheader",
		"body": [
			"<header class=\"mui-bar mui-bar-nav\">",
			"\t<a class=\"mui-action-back mui-icon mui-icon-left-nav mui-pull-left\"></a>",
			"\t<h1 class=\"mui-title\">标题</h1>",
			"</header>"
		],
		"description": "MUI标题栏(带返回箭头的标题栏)"
	},
